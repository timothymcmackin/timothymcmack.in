---
import SplashLayout from '../layouts/SplashLayout.astro';
import yaml from 'js-yaml';
import { readFileSync } from 'node:fs';
import { join } from 'node:path';

function loadYaml<T>(file: string): T {
  return yaml.load(readFileSync(join(process.cwd(), 'src/data', file), 'utf8')) as T;
}

interface SummaryData { title: string; entries: string[] }
interface RoleData { title: string; roles?: string[]; entries: string[] }
interface RichEntry { title?: string; experience: string; result?: string }
type WebflowEntry = string | RichEntry;
interface WebflowData { title: string; roles?: string[]; entries: WebflowEntry[] }
interface SstkEntry { title?: string; experience: string; result?: string }
interface SstkData { title: string; roles?: string[]; entries: SstkEntry[] }
interface EducationEntry { school: string; city: string; degree: string }
interface EducationData { title: string; entries: EducationEntry[] }

const summary   = loadYaml<SummaryData>('resume_summary.yml');
const webflow   = loadYaml<WebflowData>('resume_webflow.yml');
const trilitech = loadYaml<RoleData>('resume_trilitech.yml');
const sstk      = loadYaml<SstkData>('resume_sstk.yml');
const ibm       = loadYaml<RoleData>('resume_ibm.yml');
const education = loadYaml<EducationData>('resume_education.yml');
---

<SplashLayout title="Experience" contentClass="resume" bodyClass="layout--resume" description="Tim McMackin's work experience as a technical writer at Webflow, TriliTech, Shutterstock, and IBM.">
  <p>Click here for a PDF version: <a href="/assets/TimothyMcMackin.pdf" target="_blank">TimothyMcMackin.pdf</a></p>

  {/* Summary */}
  <div class="summary-heading heading-indent">{summary.title}</div>
  <div class="summary-flex">
    {summary.entries.map((entry, i) => (
      <>
        <div class="summary-item">{entry}</div>
        {i < summary.entries.length - 1 && (
          <div class="summary-bullet">&#8226;</div>
        )}
      </>
    ))}
  </div>

  {/* Webflow */}
  <div class="company heading-indent">{webflow.title}</div>
  {webflow.roles && (
    <ul class="roles">
      {webflow.roles.map(role => <li>{role}</li>)}
    </ul>
  )}
  {/*
    Each row in experience-grid-fromdata is a flex row with three columns:
      [experience (44%)] [arrow or spacer (62px)] [result (44%)]
    followed by a spacer-row (100% width) that creates vertical spacing between rows.

    Three cases:
    1. Plain string: rendered full-width, no columns.
    2. Object with result: experience + arrow pointing right/down + result.
    3. Object without result: experience + no-arrow-spacer (holds column width) + empty result column.
       The no-arrow-spacer keeps the experience column the same width as rows that do have arrows,
       so content aligns across all rows.
  */}
  <div class="experience-grid-fromdata">
    {webflow.entries.map(entry => {
      if (typeof entry === 'string') {
        return <div class="experience no-result" style="flex-basis:100%" set:html={entry} />;
      }
      if (entry.result) {
        return (
          <>
            <div class="experience">
              {entry.title && <div class="exp-title">{entry.title}</div>}
              <Fragment set:html={entry.experience} />
            </div>
            <div class="arrow-spacer">
              <span class="arrow is-triangle arrow-bar is-right large-breakpoints"></span>
              <span class="arrow is-triangle arrow-bar is-bottom small-breakpoints"></span>
            </div>
            <div class="result">
              <div class="spacer-result">&nbsp;</div>
              <Fragment set:html={entry.result} />
            </div>
            <div class="spacer-row">&nbsp;</div>
          </>
        );
      }
      return (
        <>
          <div class="experience no-result">
            {entry.title && <div class="exp-title">{entry.title}</div>}
            <Fragment set:html={entry.experience} />
          </div>
          <div class="no-arrow-spacer"></div>
          <div class="spacer-row">&nbsp;</div>
        </>
      );
    })}
  </div>

  {/* TriliTech */}
  <div class="company heading-indent">{trilitech.title}</div>
  {trilitech.roles && (
    <ul class="roles">
      {trilitech.roles.map(role => <li>{role}</li>)}
    </ul>
  )}
  <div class="experience-grid-fromdata">
    {trilitech.entries.map((entry, i) => (
      <>
        <div class="experience no-result" set:html={entry} />
        {i % 2 === 0 && <div class="no-arrow-spacer"></div>}
      </>
    ))}
  </div>

  {/* Shutterstock */}
  <div class="company heading-indent">{sstk.title}</div>
  {sstk.roles && (
    <ul class="roles">
      {sstk.roles.map(role => <li>{role}</li>)}
    </ul>
  )}
  <div class="experience-grid-fromdata">
    {sstk.entries.map(entry => (
      <>
        <div class="experience">
          {entry.title && <div class="exp-title">{entry.title}</div>}
          <Fragment set:html={entry.experience} />
        </div>
        <div class="arrow-spacer">
          <span class="arrow is-triangle arrow-bar is-right large-breakpoints"></span>
          <span class="arrow is-triangle arrow-bar is-bottom small-breakpoints"></span>
        </div>
        <div class="result">
          {entry.result && (
            <>
              <div class="spacer-result">&nbsp;</div>
              <Fragment set:html={entry.result} />
            </>
          )}
        </div>
        <div class="spacer-row">&nbsp;</div>
      </>
    ))}
  </div>

  {/* IBM */}
  <div class="company heading-indent">{ibm.title}</div>
  {ibm.roles && (
    <ul class="roles">
      {ibm.roles.map(role => <li>{role}</li>)}
    </ul>
  )}
  <div class="experience-grid-fromdata">
    {ibm.entries.map((entry, i) => (
      <>
        <div class="experience no-result" set:html={entry} />
        {i % 2 === 0 && <div class="no-arrow-spacer"></div>}
      </>
    ))}
  </div>

  {/* Education */}
  <div class="company heading-indent">{education.title}</div>
  <ul class="education-list">
    {education.entries.map(edu => (
      <li>{edu.degree}: {edu.school}, {edu.city}</li>
    ))}
  </ul>
</SplashLayout>
