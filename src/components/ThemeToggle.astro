---
---

<button id="theme-toggle" class="theme-toggle" type="button">
  <i class="fa-solid fa-sun theme-toggle__icon theme-toggle__icon--light" aria-hidden="true"></i>
  <i class="fa-solid fa-moon theme-toggle__icon theme-toggle__icon--dark" aria-hidden="true"></i>
  <i
    class="fa-solid fa-circle-half-stroke theme-toggle__icon theme-toggle__icon--system"
    aria-hidden="true"
  ></i>
  <span class="visually-hidden theme-toggle__label"></span>
</button>

<style>
  .theme-toggle {
    align-self: center;
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2em;
    height: 2em;
    margin-inline-start: 0.5em;
    padding: 0;
    border: 0;
    border-radius: 4px;
    background: transparent;
    color: #6f777d;
    cursor: pointer;
    font-size: 1em;
  }
  .theme-toggle:hover { background: rgba(111, 119, 125, 0.1); }
  .theme-toggle__icon { display: none; }
  :root[data-theme-preference='light'] .theme-toggle__icon--light,
  :root[data-theme-preference='dark'] .theme-toggle__icon--dark,
  :root[data-theme-preference='system'] .theme-toggle__icon--system {
    display: block;
  }
  :root[data-theme='dark'] .theme-toggle { color: #b7bbbe; }
  :root[data-theme='dark'] .theme-toggle:hover { background: rgba(216, 218, 221, 0.1); }
</style>

<script>
  const STORAGE_KEY = 'theme-preference';
  const ORDER = ['light', 'dark', 'system'] as const;
  type Preference = (typeof ORDER)[number];
  const LABEL: Record<Preference, string> = {
    light: 'Light mode',
    dark: 'Dark mode',
    system: 'System default',
  };

  function getPreference(): Preference {
    const stored = localStorage.getItem(STORAGE_KEY);
    return (ORDER as readonly string[]).includes(stored ?? '') ? (stored as Preference) : 'light';
  }

  function resolveTheme(pref: Preference): 'light' | 'dark' {
    if (pref === 'system') {
      return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    }
    return pref;
  }

  function apply(pref: Preference) {
    document.documentElement.setAttribute('data-theme', resolveTheme(pref));
    document.documentElement.setAttribute('data-theme-preference', pref);
    const button = document.getElementById('theme-toggle');
    const label = button?.querySelector<HTMLElement>('.theme-toggle__label');
    const next = ORDER[(ORDER.indexOf(pref) + 1) % ORDER.length];
    if (button) button.setAttribute('aria-label', `Appearance: ${LABEL[pref]}. Switch to ${LABEL[next]}.`);
    if (label) label.textContent = `Appearance: ${LABEL[pref]}. Switch to ${LABEL[next]}.`;
  }

  apply(getPreference());

  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const next = ORDER[(ORDER.indexOf(getPreference()) + 1) % ORDER.length];
    localStorage.setItem(STORAGE_KEY, next);
    apply(next);
  });

  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
    if (getPreference() === 'system') apply('system');
  });
</script>
